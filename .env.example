# ============================================================
#  ONE env file for the whole app (backend runtime + frontend build).
#  Copy to .env and fill in real values:  cp .env.example .env
# ============================================================

# --- Environment ---
# "development" locally. On Render set NODE_ENV=production so the backend
# serves the built frontend (Frontend/dist).
NODE_ENV=development

# --- Server ---
PORT=8000
# Comma-separated allowed origins. The FIRST entry is also used as the base URL
# for Stripe success/cancel redirects. In production set this to your Render URL,
# e.g. https://your-app.onrender.com
CORS_ORIGIN=http://localhost:5173

# --- Database ---
MONGO_URI=your_mongodb_connection_string

# --- Clerk (auth) ---
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Cloudinary (image upload) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Stripe (payments) ---
STRIPE_SECRET_KEY=sk_test_xxx
# From `stripe listen` (local) or the Stripe Dashboard webhook endpoint (prod):
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ============================================================
#  Frontend (Vite) — MUST be prefixed with VITE_. Read at BUILD time.
# ============================================================
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Where the frontend sends API calls.
#  - Local dev (separate ports): http://localhost:8000
#  - Production single-service deploy (same origin): leave EMPTY -> relative /api/v1
VITE_BACKEND_URL=http://localhost:8000
